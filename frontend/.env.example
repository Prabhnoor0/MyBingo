# ============================================================
# SageWillow Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# All variables must be prefixed with VITE_ to be exposed to the browser.

# ─── Backend API ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api

# ─── Firebase (client-side SDK for Auth) ─────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app → SDK snippet
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=welly-df3f6.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=welly-df3f6
VITE_FIREBASE_STORAGE_BUCKET=welly-df3f6.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── YouTube Data API v3 (for Breathing/Meditation page) ─────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_YOUTUBE_API_KEY=
